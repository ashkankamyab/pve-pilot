# =============================================================================
# PVE Pilot Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Proxmox Connection
# Create an API token in PVE: Datacenter > Permissions > API Tokens
# Grant PVEAdmin role: pveum aclmod / -token 'root@pam!pilot' -role PVEAdmin
PROXMOX_URL=https://192.168.1.100:8006
PROXMOX_TOKEN_ID=root@pam!pilot
PROXMOX_TOKEN_SECRET=00000000-0000-0000-0000-000000000000

# Skip TLS certificate verification (true for self-signed PVE certs)
INSECURE_TLS=true

# Frontend URL (for CORS). Change if running frontend on a different host/port.
FRONTEND_URL=http://localhost:3000

# API URL (used by the frontend at build time to reach the backend)
NEXT_PUBLIC_API_URL=http://localhost:8080

# DNS domain (optional). Sets searchdomain on provisioned VMs via cloud-init.
# DNS_DOMAIN=example.com

# Backup storage (Proxmox storage pool name for vzdump backups)
BACKUP_STORAGE=nfs-drive

# ---------------------------------------------------------------------------
# LXC Credential Injection (optional)
# ---------------------------------------------------------------------------
# PVE Pilot can SSH to the Proxmox host to run `pct exec` for setting
# passwords, SSH keys, and user-data scripts inside LXC containers.
# Leave blank to disable LXC credential injection.

# PROXMOX_SSH_HOST=192.168.1.100
# PROXMOX_SSH_PORT=22
# PROXMOX_SSH_USER=root

# Path on the Docker HOST to the SSH private key (mounted read-only into the container)
# PROXMOX_SSH_KEY_HOST_PATH=/home/you/.ssh/id_ed25519
