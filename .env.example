# =============================================================================
# PVE Pilot Configuration
# =============================================================================

# Proxmox Connection
# Create an API token in PVE: Datacenter → Permissions → API Tokens
PROXMOX_URL=https://192.168.1.100:8006
PROXMOX_TOKEN_ID=root@pam!pilot
PROXMOX_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Skip TLS certificate verification (true for self-signed PVE certs)
INSECURE_TLS=true

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# API URL (for frontend to reach backend)
NEXT_PUBLIC_API_URL=http://localhost:8080
